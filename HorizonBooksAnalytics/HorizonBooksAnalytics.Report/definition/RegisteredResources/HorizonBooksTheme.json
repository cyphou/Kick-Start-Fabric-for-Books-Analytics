{
  "name": "HorizonBooksTheme",
  "dataColors": [
    "#5B2C3F",
    "#C7944A",
    "#2C5F4B",
    "#8B5E3C",
    "#3D6B8E",
    "#9B4D5A",
    "#D4A95A",
    "#4A7C6F",
    "#7A4F7A",
    "#B85C3A",
    "#3B6B5E",
    "#A0522D"
  ],
  "background": "#FAF6F0",
  "foreground": "#2D2621",
  "tableAccent": "#5B2C3F",
  "textClasses": {
    "title": {
      "fontFace": "Georgia",
      "fontSize": 14,
      "color": "#2D2621"
    },
    "header": {
      "fontFace": "Georgia",
      "fontSize": 12,
      "color": "#2D2621"
    },
    "callout": {
      "fontFace": "Georgia",
      "fontSize": 32,
      "color": "#5B2C3F"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#4A4540"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#FFFDF8" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "color": { "solid": { "color": "#D4C5B0" } },
            "show": true
          }
        ],
        "visualHeader": [
          {
            "background": { "solid": { "color": "#FFFDF8" } },
            "transparency": 100
          }
        ],
        "title": [
          {
            "fontFamily": "Georgia",
            "fontSize": 13,
            "fontColor": { "solid": { "color": "#2D2621" } },
            "bold": true
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#5B2C3F" } },
            "fontSize": 28,
            "fontFamily": "Georgia"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#6B6560" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "general": [
          {
            "outlineColor": { "solid": { "color": "#D4C5B0" } },
            "outlineWeight": 1
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#2D2621" } },
            "background": { "solid": { "color": "#FFFDF8" } },
            "fontFamily": "Segoe UI"
          }
        ],
        "header": [
          {
            "fontColor": { "solid": { "color": "#5B2C3F" } },
            "fontFamily": "Georgia",
            "fontSize": 11,
            "background": { "solid": { "color": "#FFFDF8" } }
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "lineStyles": [
          {
            "strokeWidth": 3
          }
        ]
      }
    },
    "columnChart": {
      "*": {
        "dataPoint": [
          {
            "fill": { "solid": { "color": "#5B2C3F" } }
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [
          {
            "fill": { "solid": { "color": "#C7944A" } }
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": { "solid": { "color": "#E8DDD0" } },
            "gridVerticalWeight": 1,
            "gridHorizontalColor": { "solid": { "color": "#E8DDD0" } },
            "gridHorizontalWeight": 1
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFDF8" } },
            "backColor": { "solid": { "color": "#5B2C3F" } },
            "fontFamily": "Georgia",
            "fontSize": 11
          }
        ],
        "values": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "fontColor": { "solid": { "color": "#2D2621" } },
            "backColor": { "solid": { "color": "#FFFDF8" } }
          }
        ],
        "total": [
          {
            "fontColor": { "solid": { "color": "#FFFDF8" } },
            "backColor": { "solid": { "color": "#8B5E3C" } },
            "fontFamily": "Georgia"
          }
        ]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFDF8" } },
            "backColor": { "solid": { "color": "#5B2C3F" } },
            "fontFamily": "Georgia"
          }
        ],
        "rowHeaders": [
          {
            "fontColor": { "solid": { "color": "#2D2621" } },
            "fontFamily": "Segoe UI"
          }
        ],
        "values": [
          {
            "fontFamily": "Segoe UI",
            "fontColor": { "solid": { "color": "#2D2621" } }
          }
        ]
      }
    },
    "shape": {
      "*": {
        "fill": [
          {
            "fillColor": { "solid": { "color": "#5B2C3F" } },
            "show": true,
            "transparency": 0
          }
        ],
        "line": [
          {
            "show": false
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "transparent" } },
            "transparency": 100
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#FAF6F0" } },
            "transparency": 0
          }
        ]
      }
    }
  },
  "good": "#2C5F4B",
  "neutral": "#C7944A",
  "bad": "#9B4D5A",
  "maximum": "#2C5F4B",
  "center": "#C7944A",
  "minimum": "#9B4D5A"
}
