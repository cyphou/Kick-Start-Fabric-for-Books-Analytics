		sourceColumn: LowerBound
		lineageTag: 30000002-0001-0001-0001-200000000005

		annotation SummarizationSetBy = Automatic

	column UpperBound
		dataType: double
		summarizeBy: sum
		sourceColumn: UpperBound
		lineageTag: 30000002-0001-0001-0001-200000000006

		annotation SummarizationSetBy = Automatic

	column ForecastHorizon
