table 'Budget'
	lineageTag: 20000002-0001-0001-0001-000000000001

	measure 'Budget Amount' = SUM('Budget'[Budgeted Amount])
		formatString: $#,0;($#,0)
		displayFolder: Finance \ Budget
		lineageTag: 20000002-0001-0001-0001-100000000001

	measure 'Actual Amount' = SUM('Budget'[Actual Spent])
		formatString: $#,0;($#,0)
		displayFolder: Finance \ Budget
		lineageTag: 20000002-0001-0001-0001-100000000002

	measure 'Budget Variance' = SUM('Budget'[Variance])
		formatString: $#,0;($#,0)
		displayFolder: Finance \ Budget
		lineageTag: 20000002-0001-0001-0001-100000000003

	measure 'Budget Variance %' = DIVIDE([Budget Variance],ABS([Budget Amount]),0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Finance \ Budget
		lineageTag: 20000002-0001-0001-0001-100000000004

	measure 'Budget Attainment' = DIVIDE([Actual Amount],[Budget Amount],0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Finance \ Budget
		lineageTag: 20000002-0001-0001-0001-100000000005

	column 'Budget ID'
		dataType: string
		summarizeBy: none
		sourceColumn: BudgetID
		lineageTag: 20000002-0001-0001-0001-200000000001

		annotation SummarizationSetBy = Automatic

	column 'Fiscal Year'
		dataType: string
