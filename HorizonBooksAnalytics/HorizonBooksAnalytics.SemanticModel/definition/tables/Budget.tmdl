		summarizeBy: none
		sourceColumn: FiscalMonth
		lineageTag: 20000002-0001-0001-0001-200000000004

		annotation SummarizationSetBy = Automatic

	column 'Account ID'
		dataType: int64
		summarizeBy: none
		sourceColumn: AccountID
		lineageTag: 20000002-0001-0001-0001-200000000005

		annotation SummarizationSetBy = Automatic

	column 'Cost Center ID'
		dataType: string
		summarizeBy: none
		sourceColumn: CostCenterID
		lineageTag: 20000002-0001-0001-0001-200000000006

		annotation SummarizationSetBy = Automatic

	column 'Budgeted Amount'
