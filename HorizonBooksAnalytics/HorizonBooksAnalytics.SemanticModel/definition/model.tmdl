model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Date","Accounts","Cost Centers","Books","Authors","Geography","Customers","Employees","Departments","Warehouses","Financial Transactions","Budget","Orders","Inventory","Returns","Payroll","Performance Reviews","Recruitment","Forecast Sales Revenue","Forecast Genre Demand","Forecast Financial","Forecast Inventory Demand","Forecast Workforce"]

ref table 'Date'
ref table 'Accounts'
ref table 'Cost Centers'
ref table 'Books'
ref table 'Authors'
ref table 'Geography'
ref table 'Customers'
ref table 'Employees'
ref table 'Departments'
ref table 'Warehouses'
ref table 'Financial Transactions'
ref table 'Budget'
ref table 'Orders'
ref table 'Inventory'
ref table 'Returns'
ref table 'Payroll'
ref table 'Performance Reviews'
ref table 'Recruitment'
ref table 'Forecast Sales Revenue'
ref table 'Forecast Genre Demand'
ref table 'Forecast Financial'
ref table 'Forecast Inventory Demand'
ref table 'Forecast Workforce'

ref expression DatabaseQuery

queryGroup DatabaseQuery

annotation PBI_QueryRelationships = []
