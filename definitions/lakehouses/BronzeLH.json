{
  "displayName": "BronzeLH",
  "type": "Lakehouse",
  "description": "Horizon Books Bronze layer - raw CSV files for Finance, HR, Operations",
  "creationPayload": {
    "enableSchemas": true
  },
  "layer": "Bronze",
  "purpose": "Landing zone for raw data files. CSVs uploaded to Files/, Dataflow Gen2 loads tables to Tables/.",
  "schemas": {
    "dbo": "Default schema for Dataflow-loaded raw tables"
  },
  "expectedContent": {
