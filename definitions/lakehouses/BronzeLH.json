      "Files/Finance/DimCostCenters.csv",
      "Files/Finance/FactFinancialTransactions.csv",
      "Files/Finance/FactBudget.csv",
      "Files/HR/DimEmployees.csv",
      "Files/HR/DimDepartments.csv",
      "Files/HR/FactPayroll.csv",
      "Files/HR/FactPerformanceReviews.csv",
      "Files/HR/FactRecruitment.csv",
      "Files/Operations/DimBooks.csv",
      "Files/Operations/DimAuthors.csv",
      "Files/Operations/DimCustomers.csv",
      "Files/Operations/DimGeography.csv",
      "Files/Operations/DimWarehouses.csv",
      "Files/Operations/FactOrders.csv",
      "Files/Operations/FactInventory.csv",
      "Files/Operations/FactReturns.csv"
